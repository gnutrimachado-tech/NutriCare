generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model agendamentos {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paciente_id      String    @db.Uuid
  data_agendamento DateTime  @db.Date
  horario          DateTime  @db.Time(6)
  tipo             String?   @db.VarChar(50)
  status           String?   @default("Agendado") @db.VarChar(50)
  observacoes      String?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  pacientes        pacientes @relation(fields: [paciente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([data_agendamento], map: "idx_agendamentos_data")
}

model alimentos {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome           String           @db.VarChar(200)
  categoria      String?          @db.VarChar(100)
  calorias       Decimal?         @db.Decimal(8, 2)
  proteinas      Decimal?         @db.Decimal(8, 2)
  carboidratos   Decimal?         @db.Decimal(8, 2)
  gorduras       Decimal?         @db.Decimal(8, 2)
  fibras         Decimal?         @db.Decimal(8, 2)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  refeicao_itens refeicao_itens[]
}

model anamneses {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paciente_id         String    @db.Uuid
  peso                Decimal?  @db.Decimal(6, 2)
  altura              Decimal?  @db.Decimal(6, 2)
  imc                 Decimal?  @db.Decimal(6, 2)
  percentual_gordura  Decimal?  @db.Decimal(5, 2)
  massa_muscular      Decimal?  @db.Decimal(6, 2)
  massa_adiposa       Decimal?  @db.Decimal(6, 2)
  agua_corporal       Decimal?  @db.Decimal(5, 2)
  taxa_metabolica     Decimal?  @db.Decimal(8, 2)
  historico_clinico   String?
  alergias            String?
  medicamentos        String?
  suplementos         String?
  habitos_alimentares String?
  observacoes         String?
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  pacientes           pacientes @relation(fields: [paciente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model evolucao_corporal {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paciente_id              String    @db.Uuid
  data_avaliacao           DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  peso                     Decimal?  @db.Decimal(6, 2)
  percentual_gordura       Decimal?  @db.Decimal(5, 2)
  massa_muscular           Decimal?  @db.Decimal(6, 2)
  circunferencia_abdominal Decimal?  @db.Decimal(6, 2)
  observacoes              String?
  created_at               DateTime? @default(now()) @db.Timestamp(6)
  pacientes                pacientes @relation(fields: [paciente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model formulario_tokens {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paciente_id String    @db.Uuid
  token       String    @unique @db.VarChar(64)
  campos      String[]
  status      String    @default("pendente") @db.VarChar(20)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  expires_at  DateTime  @db.Timestamp(6)
  pacientes   pacientes @relation(fields: [paciente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model nutricionistas {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome       String      @db.VarChar(150)
  email      String      @unique @db.VarChar(150)
  senha_hash String
  telefone   String?     @db.VarChar(30)
  crn        String?     @db.VarChar(30)
  created_at DateTime?   @default(now()) @db.Timestamp(6)
  pacientes  pacientes[]
}

model pacientes {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nutricionista_id   String               @db.Uuid
  nome               String               @db.VarChar(150)
  email              String?              @db.VarChar(150)
  telefone           String?              @db.VarChar(30)
  data_nascimento    DateTime?            @db.Date
  sexo               String?              @db.VarChar(20)
  profissao          String?              @db.VarChar(100)
  estado_civil       String?              @db.VarChar(50)
  objetivo           String?
  observacoes        String?
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  updated_at         DateTime?            @default(now()) @db.Timestamp(6)
  agendamentos       agendamentos[]
  anamneses          anamneses[]
  evolucao_corporal  evolucao_corporal[]
  formulario_tokens  formulario_tokens[]
  nutricionistas     nutricionistas       @relation(fields: [nutricionista_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  planos_alimentares planos_alimentares[]

  @@index([nutricionista_id], map: "idx_pacientes_nutricionista")
}

model planos_alimentares {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paciente_id         String      @db.Uuid
  nome                String?     @db.VarChar(150)
  objetivo            String?
  calorias_totais     Decimal?    @db.Decimal(8, 2)
  proteinas_totais    Decimal?    @db.Decimal(8, 2)
  carboidratos_totais Decimal?    @db.Decimal(8, 2)
  gorduras_totais     Decimal?    @db.Decimal(8, 2)
  created_at          DateTime?   @default(now()) @db.Timestamp(6)
  pacientes           pacientes   @relation(fields: [paciente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  refeicoes           refeicoes[]

  @@index([paciente_id], map: "idx_planos_paciente")
}

model refeicao_itens {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  refeicao_id  String    @db.Uuid
  alimento_id  String    @db.Uuid
  quantidade   Decimal?  @db.Decimal(10, 2)
  unidade      String?   @db.VarChar(30)
  calorias     Decimal?  @db.Decimal(8, 2)
  proteinas    Decimal?  @db.Decimal(8, 2)
  carboidratos Decimal?  @db.Decimal(8, 2)
  gorduras     Decimal?  @db.Decimal(8, 2)
  alimentos    alimentos @relation(fields: [alimento_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  refeicoes    refeicoes @relation(fields: [refeicao_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model refeicoes {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plano_id           String             @db.Uuid
  nome               String             @db.VarChar(100)
  horario            DateTime?          @db.Time(6)
  observacoes        String?
  created_at         DateTime?          @default(now()) @db.Timestamp(6)
  refeicao_itens     refeicao_itens[]
  planos_alimentares planos_alimentares @relation(fields: [plano_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
